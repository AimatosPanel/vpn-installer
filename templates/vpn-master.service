[Unit]
Description=AimatosPanel VPN Master Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory={{INSTALL_DIR}}/vpn-master
ExecStart={{INSTALL_DIR}}/vpn-master/vpn-master
Restart=always
RestartSec=5
Environment=PORT={{PORT}}
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target